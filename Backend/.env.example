# ── Database ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/dppsmart

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_use_at_least_64_chars_of_random_data
JWT_EXPIRATION=900000

# ── Email (Gmail SMTP) ────────────────────────────────────────────────────────
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your_app_password

# ── Frontend & CORS ───────────────────────────────────────────────────────────
FRONTEND_BASE_URL=http://localhost:3000
# Comma-separated pattern list. Wildcards allowed for ports: http://localhost:*
CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:*,http://127.0.0.1:*

# ── Google OAuth2 ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── Groq AI ───────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_MODEL=llama-3.3-70b-versatile

# ── Google Maps ───────────────────────────────────────────────────────────────
GOOGLE_MAPS_SERVER_KEY=your_google_maps_server_key

# ── Cloudinary ────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# auth endpoints (login, register, refresh, forgot-password)
RATE_LIMIT_AUTH_REQUESTS=10
RATE_LIMIT_AUTH_WINDOW_SECONDS=60
# public endpoints (scans, DPP, landing)
RATE_LIMIT_PUBLIC_REQUESTS=30
RATE_LIMIT_PUBLIC_WINDOW_SECONDS=60
# AI chat endpoints
RATE_LIMIT_AI_REQUESTS=20
RATE_LIMIT_AI_WINDOW_SECONDS=60
